{
  "id": "openai-codex-oauth-proxy-failure",
  "title": "OpenAI Codex OAuth token exchange fails behind HTTP proxy",
  "category": "auth",
  "severity": "error",
  "summary": "Fix OpenAI Codex OAuth token exchange behind HTTP proxy environments.",
  "enabledByDefault": true,
  "capabilities": {
    "preflight": false,
    "runtime": true,
    "repair": false
  },
  "triggers": {
    "argvAll": ["models", "auth", "login"],
    "provider": "openai-codex"
  },
  "entry": {
    "runtime": "./runtime.mjs"
  },
  "env": {
    "variables": [
      "OPENCLAW_GUARDIAN_ISSUE_OPENAI_CODEX_OAUTH_PROXY_FAILURE_DISABLE",
      "OPENCLAW_GUARDIAN_ISSUE_OPENAI_CODEX_OAUTH_PROXY_FAILURE_CURL_FALLBACK_DISABLE",
      "OPENCLAW_GUARDIAN_ISSUE_OPENAI_CODEX_OAUTH_PROXY_FAILURE_STDERR",
      "OPENCLAW_GUARDIAN_ISSUE_OPENAI_CODEX_OAUTH_PROXY_FAILURE_OPENCLAW_ROOT"
    ]
  },
  "logging": {
    "file": "openai-codex-oauth-proxy-failure.log"
  },
  "upstream": {
    "recommendedCommands": ["openclaw doctor"],
    "coverage": "partial"
  }
}
