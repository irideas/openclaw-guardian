{
  "id": "openai-codex-auth-proxy",
  "description": "Fix OpenAI Codex OAuth token exchange behind HTTP proxy environments.",
  "match": {
    "argvAll": ["models", "auth", "login"],
    "provider": "openai-codex"
  },
  "entry": {
    "preload": "./preload-hook.mjs"
  },
  "logging": {
    "file": "openai-codex-auth-proxy.log"
  }
}

